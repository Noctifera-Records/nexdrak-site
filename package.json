{
  "name": "nexdrak-site",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "vercel-build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "npm run build:ci && npx wrangler pages deploy .open-next/assets --project-name nex-website --compatibility-flag=nodejs_compat --compatibility-date=2024-11-18",
    "build:ci": "opennextjs-cloudflare build && node scripts/prepare-cf-assets.js",
    "analyze": "ANALYZE=true npm run build",
    "optimize-images": "node scripts/optimize-images.js",
    "lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "perf": "npm run build && npm run lighthouse",
    "auth:generate": "npx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ./lib/db/auth.schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
